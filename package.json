{
  "name": "electron-session-proxy",
  "version": "1.0.0",
  "description": "A socks proxy with user authentication can be set for electron's session",
  "keywords": [
    "electron",
    "electron-session",
    "socks",
    "proxy"
  ],
  "author": "MissGwen <missgwen0211@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MissGwen/electron-session-proxy.git"
  },
  "homepage": "https://github.com/MissGwen/electron-session-proxy",
  "bugs": {
    "url": "https://github.com/MissGwen/electron-session-proxy/issues"
  },
  "type": "module",
  "main": "./dist/main.umd.cjs",
  "module": "./dist/main.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.umd.cjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "private": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "socks": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.9",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  }
}
